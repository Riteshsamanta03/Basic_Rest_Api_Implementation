<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit your Post</title>

    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <!-- Back Button -->
    <div class="back">
        <a href="/posts">← Back to Posts</a>
    </div>

    <h2 class="form-title">Edit your Post</h2>

    <div class="form-container">

        <p class="post-id">Post ID: <span><%= post.id %></span></p>
        <p class="user">@<%= post.username %></p>

        <form method="post" action="/posts/<%= post.id %>?_method=PATCH">

            <label>Image URL</label>
            <input 
                type="url" 
                name="image" 
                placeholder="Paste your image link"
                value="<%= post.image %>"
                required
            />

            <label>Caption</label>
            <textarea 
                name="caption" 
                rows="5"
                required
            ><%= post.caption %></textarea>

            <button type="submit" class="submit-btn">Update Post</button>

        </form>
    </div>

</body>
</html>